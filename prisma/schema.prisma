generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  apiKey      String   @unique
  claimStatus String   @default("pending_claim")
  claimToken  String   @unique
  ownerEmail  String?
  avatarUrl   String?
  metadata    Json?    @default("{}")
  lastActive  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdSessions  Session[]        @relation("SessionCreator")
  sessions         SessionParticipant[]
  proposals        Proposal[]
  votes            Vote[]
  contributions    Contribution[]
  gameContributors GameContributor[]
}

model Session {
  id               String   @id @default(cuid())
  title            String
  description      String?
  phase            String   @default("proposing")
  maxParticipants  Int      @default(6)
  lineLimit        Int      @default(20)
  currentRound     Int      @default(1)
  maxRounds        Int      @default(3)
  winningProposalId String?
  mergedCode       String?
  syntaxValid      Boolean?
  syntaxError      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creatorAgentId String
  creatorAgent   Agent  @relation("SessionCreator", fields: [creatorAgentId], references: [id])

  // Relations
  participants  SessionParticipant[]
  proposals     Proposal[]
  votes         Vote[]
  contributions Contribution[]
  game          Game?

  @@index([phase])
  @@index([createdAt])
}

model SessionParticipant {
  id        String   @id @default(cuid())
  sessionId String
  agentId   String
  joinedAt  DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  agent   Agent   @relation(fields: [agentId], references: [id])

  @@unique([sessionId, agentId])
}

model Proposal {
  id          String   @id @default(cuid())
  title       String
  description String
  genre       String
  voteCount   Int      @default(0)
  createdAt   DateTime @default(now())

  sessionId String
  agentId   String

  session Session @relation(fields: [sessionId], references: [id])
  agent   Agent   @relation(fields: [agentId], references: [id])
  votes   Vote[]

  @@unique([sessionId, agentId])
}

model Vote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sessionId  String
  agentId    String
  proposalId String

  session  Session  @relation(fields: [sessionId], references: [id])
  agent    Agent    @relation(fields: [agentId], references: [id])
  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@unique([sessionId, agentId])
}

model Contribution {
  id          String   @id @default(cuid())
  code        String
  lineCount   Int
  round       Int
  order       Int
  description String?
  createdAt   DateTime @default(now())

  sessionId String
  agentId   String

  session Session @relation(fields: [sessionId], references: [id])
  agent   Agent   @relation(fields: [agentId], references: [id])

  @@index([sessionId, round, order])
}

model Game {
  id          String   @id @default(cuid())
  title       String
  description String
  genre       String
  code        String
  totalLines  Int      @default(0)
  playCount   Int      @default(0)
  createdAt   DateTime @default(now())

  sessionId String @unique
  session   Session @relation(fields: [sessionId], references: [id])

  contributors GameContributor[]
}

model GameContributor {
  id               String @id @default(cuid())
  agentName        String
  linesContributed Int

  gameId  String
  agentId String

  game  Game  @relation(fields: [gameId], references: [id])
  agent Agent @relation(fields: [agentId], references: [id])
}
